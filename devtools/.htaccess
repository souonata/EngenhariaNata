# ============================================
# HEADERS DE SEGURANÇA PARA DEVTOOLS
# ============================================
# CSP mais permissivo para permitir iframes e Blob URLs
<IfModule mod_headers.c>
    # Content Security Policy (CSP) - Permissivo para DevTools
    # Permite iframes do próprio site e Blob URLs para preview
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://docs.google.com https://script.google.com blob:; style-src 'self' 'unsafe-inline' blob:; img-src 'self' data: https: blob:; font-src 'self' data: blob:; connect-src 'self' https://docs.google.com https://script.google.com https://*.googleapis.com blob:; frame-src 'self' https://docs.google.com blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://docs.google.com; upgrade-insecure-requests;"
    
    # X-Frame-Options: Permite que DevTools seja carregado em iframes (necessário para preview)
    Header set X-Frame-Options "SAMEORIGIN"
    
    # X-Content-Type-Options: Previne MIME type sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # X-XSS-Protection: Ativa proteção XSS
    Header set X-XSS-Protection "1; mode=block"
    
    # Referrer-Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove informações do servidor
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ============================================
# CONFIGURAÇÕES DE CACHE
# ============================================

# Desabilitar cache para arquivos HTML, CSS e JS do DevTools
<FilesMatch "\.(html|htm|css|js)$">
    FileETag None
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</FilesMatch>

