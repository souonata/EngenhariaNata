# Provedor de modelo: ollama ou openrouter
LLM_PROVIDER=ollama

# URL do endpoint de chat do Ollama local
OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Modelo fixo da API local
OLLAMA_MODEL=gpt-oss:20b

# OpenRouter (necessario apenas se LLM_PROVIDER=openrouter)
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=
OPENROUTER_MODEL_HUNTER_ALPHA=
OPENROUTER_MODEL_HEALER_ALPHA=

# Opcional para telemetria OpenRouter
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=EngenhariaNata Local API

# Token obrigatorio para frontend
API_BEARER_TOKEN=troque-por-um-token-forte

# Opcional: lista de tokens (separados por virgula) para varios convidados
# Se definido, tem prioridade sobre API_BEARER_TOKEN
API_BEARER_TOKENS=convidado-01-local,convidado-02-local,convidado-03-local

# Origens permitidas (separadas por virgula)
ALLOWED_ORIGINS=https://engnata.infinityfree.me,https://engnata.eu

# Limites operacionais
REQUEST_TIMEOUT_SECONDS=120
RATE_LIMIT_PER_MINUTE=20
MAX_PROMPT_CHARS=4000

# Prompt de sistema opcional
SYSTEM_PROMPT=
