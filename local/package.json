{
  "name": "engenharia-nata",
  "version": "1.0.2",
  "description": "Portfólio de apps web educativos para engenharia e finanças - JavaScript puro, bilíngue PT/IT",
  "type": "module",
  "scripts": {
    "control": "node server-control.js",
    "dev:controlled": "npm run control",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js --fix",
    "lint:check": "eslint . --ext .js",
    "format": "prettier --write \"**/*.{js,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,json,md}\"",
    "style:lint": "stylelint \"**/*.css\" --fix --allow-empty-input",
    "style:check": "stylelint \"**/*.css\" --allow-empty-input",
    "version:patch": "node scripts/update-versions.js patch",
    "version:minor": "node scripts/update-versions.js minor",
    "version:major": "node scripts/update-versions.js major",
    "checkup": "rg \"console\\.log|\\bdebugger\\b\" -g \"*.js\" -n ../index-script.js ../sw.js ../assets ../src ../aquecimento ../arcondicionado ../bitola ../bombaagua ../bugs ../chuva ../fazenda ../helice ../iluminacao ../mutuo ../salario ../sobre ../solar ../template-app ../ventilacao || echo 'OK: nenhum console.log ou debugger encontrado'",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "test:coverage": "vitest run --coverage --config vitest.config.js",
    "validate": "npm run lint:check && npm run format:check && npm run style:check && npm test",
    "prebuild": "npm run lint:check"
  },
  "keywords": [
    "engenharia",
    "calculadora",
    "educacional",
    "javascript",
    "portugues",
    "italiano",
    "solar",
    "helice",
    "bitola",
    "financiamento"
  ],
  "author": "EngenhariaNata",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/souonata/EngenhariaNata.git"
  },
  "homepage": "https://souonata.github.io/EngenhariaNata",
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "chart.js": "4.4.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "stylelint": "^16.1.0",
    "stylelint-config-standard": "^36.0.0",
    "terser": "^5.27.0",
    "vite": "7.3.0",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
